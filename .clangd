# https://clangd.llvm.org/config
---
CompileFlags:
  CompilationDatabase: build

Diagnostics:
  Includes:
    IgnoreHeader:
      - \.moc$
---
If:
  PathMatch: .*\.(h|hh|hpp|hxx|inc)

CompileFlags:
  Add:
    - -Wno-unneeded-internal-declaration
    - -Wno-unused-const-variable
    - -Wno-unused-function
    - -Wno-unused-variable
---
If:
  PathMatch: 3rdParty/.*

Diagnostics:
  Suppress: "*"
