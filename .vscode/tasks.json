{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure Linux Debug",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "linux-debug"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake: Build Linux Debug",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "linux-debug"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "CMake: Configure Linux Release",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "linux-release"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake: Build Linux Release",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "linux-release"],
      "group": "build",
      "problemMatcher": "$gcc"
    }
  ]
}
